# Optional AI text provider
OPENAI_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free

# Meta Graph API
META_GRAPH_VERSION=
META_ACCESS_TOKEN=
INSTAGRAM_ACCESS_TOKEN=
META_PAGE_ID=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_USERNAME=
PUBLIC_IMAGE_URL=
PUBLIC_VIDEO_URL=

# Optional free media hosting for direct Instagram posting.
# If GITHUB_TOKEN is blank, the PowerShell runner falls back to Catbox anonymous hosting.
GITHUB_TOKEN=
GITHUB_REPOSITORY=chetan638282u/viral-social-publisher
GITHUB_MEDIA_BRANCH=main
GITHUB_MEDIA_PATH=media

# LinkedIn
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=urn:li:person:YOUR_PERSON_ID

# YouTube
YOUTUBE_CLIENT_SECRETS_FILE=client_secret.json

# Telegram approval bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
APPROVED_PLATFORMS=dry_run
